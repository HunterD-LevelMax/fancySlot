<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.FancySlot" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Статус бар темного цвета -->
        <item name="android:statusBarColor">@color/fancy_deep_purple</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>

        <!-- Навигейшн бар -->
        <item name="android:navigationBarColor">@color/fancy_background</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>

        <!-- Основные цвета темы -->
        <item name="colorPrimary">@color/fancy_purple</item>
        <item name="colorPrimaryDark">@color/fancy_dark_purple</item>
        <item name="colorPrimaryVariant">@color/fancy_deep_purple</item>
        <item name="colorSecondary">@color/fancy_accent</item>
        <item name="colorSecondaryVariant">@color/fancy_card</item>
        <item name="colorSurface">@color/fancy_surface</item>
        <item name="colorError">@color/fancy_error</item>

        <!-- Цвета для Material 3 -->
        <item name="android:colorPrimary">@color/fancy_purple</item>
        <item name="android:colorBackground">@color/fancy_background</item>

        <!-- Текст -->
        <item name="android:textColorPrimary">@color/fancy_text_primary</item>
        <item name="android:textColorSecondary">@color/fancy_text_secondary</item>
        <item name="android:textColorHint">@color/fancy_text_hint</item>

        <!-- Акценты -->
        <item name="colorControlHighlight">#40FFFFFF</item>
        <item name="colorControlActivated">@color/fancy_purple</item>

        <!-- Анимации и переходы -->
        <item name="android:windowAnimationStyle">@style/Animation.Fancy</item>

        <!-- Шрифты -->
        <item name="android:fontFamily">@font/patrick_hand</item>
    </style>

    <!-- Стиль для кнопок -->
    <style name="FancyButton" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/fancy_text_primary</item>
        <item name="android:backgroundTint">@color/fancy_purple</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/patrick_hand</item>
    </style>

    <!-- Стиль для карточек -->
    <style name="FancyCard" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/fancy_card</item>
        <item name="cardElevation">8dp</item>
        <item name="android:stateListAnimator">@animator/fancy_card_elevation</item>
    </style>

    <!-- Стиль для полей ввода -->
    <style name="FancyEditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/fancy_text_primary</item>
        <item name="android:textColorHint">@color/fancy_text_hint</item>
        <item name="android:background">@drawable/fancy_edittext_background</item>
        <item name="android:padding">16dp</item>
        <item name="android:fontFamily">@font/patrick_hand</item>
    </style>

    <!-- Анимации -->
    <style name="Animation.Fancy" parent="android:Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/fancy_fade_in</item>
        <item name="android:activityOpenExitAnimation">@anim/fancy_fade_out</item>
        <item name="android:activityCloseEnterAnimation">@anim/fancy_fade_in</item>
        <item name="android:activityCloseExitAnimation">@anim/fancy_fade_out</item>
    </style>
</resources>